# Copy to .env and fill in. .env is gitignored.
#
# Used by `npm run deploy` (which calls scripts/run-daily-report.mjs which
# drives the gradicus MCP server's daily_report tool).

# Required when syncing from Gradicus
GRADICUS_EMAIL=you@example.com
GRADICUS_PASSWORD=your-password

# Required when deploying to Netlify
# Get one at https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_AUTH_TOKEN=nfp_paste_token_here

# Optional — defaults to the gradicus-mcp site
# NETLIFY_SITE_ID=13e4d96b-833c-4950-9e0c-f2dbca58a807

# PWA assets (manifest, sw.js, icons) live in report/static/ and are
# committed to the repo. To regenerate icon sizes from a new source PNG:
#   npm run build:icons
